generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                     String               @id @default(cuid())
  email                  String               @unique
  phone                  String?              @unique
  name                   String?
  role                   UserRole             @default(CUSTOMER)
  password               String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  dealerId               String?
  auctions               Auction[]            @relation("seller")
  auditLogs              AuditLog[]
  bids                   Bid[]
  blogPosts              BlogPost[]
  financeApplications    FinanceApplication[]
  importQuotes           ImportQuote[]
  inspectionReports      InspectionReport[]
  notifications          Notification[]
  payments               Payment[]
  sessions               Session[]
  supportMessages        SupportMessage[]
  assignedSupportTickets SupportTicket[]      @relation("assignedSupport")
  supportTickets         SupportTicket[]
  dealer                 Dealer?              @relation(fields: [dealerId], references: [id])
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String
  createdAt    DateTime @default(now())
  expiresAt    DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model Dealer {
  id           String    @id @default(cuid())
  name         String
  code         String    @unique
  contactName  String?
  contactPhone String?
  address      String?
  createdAt    DateTime  @default(now())
  users        User[]
  vehicles     Vehicle[]
}

model Vehicle {
  id                  String               @id @default(cuid())
  vin                 String               @unique
  make                String
  model               String
  trim                String?
  year                Int
  mileage             Int?
  condition           VehicleCondition     @default(USED)
  color               String?
  transmission        String?
  engine              String?
  description         String?
  dealerId            String
  brandId             String?
  categoryId          String?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  index_vin           String?              @map("vin_index")
  auctions            Auction[]
  financeApplications FinanceApplication[]
  inspections         InspectionReport[]
  shipments           Shipment[]
  brand               Brand?               @relation(fields: [brandId], references: [id])
  category            Category?            @relation(fields: [categoryId], references: [id])
  dealer              Dealer               @relation(fields: [dealerId], references: [id])
  images              VehicleImage[]
}

model VehicleImage {
  id        String   @id @default(cuid())
  vehicleId String
  url       String
  publicId  String?
  metadata  Json?
  createdAt DateTime @default(now())
  vehicle   Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Auction {
  id            String        @id @default(cuid())
  title         String
  description   String?
  vehicleId     String
  sellerId      String
  startingPrice Float
  reservePrice  Float?
  currentPrice  Float?
  startAt       DateTime
  endAt         DateTime
  status        AuctionStatus @default(DRAFT)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  seller        User          @relation("seller", fields: [sellerId], references: [id])
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id])
  bids          Bid[]
}

model Bid {
  id        String   @id @default(cuid())
  auctionId String
  bidderId  String
  amount    Float
  createdAt DateTime @default(now())
  auction   Auction  @relation(fields: [auctionId], references: [id])
  bidder    User     @relation(fields: [bidderId], references: [id])
}

model FinanceApplication {
  id           String   @id @default(cuid())
  userId       String
  vehicleId    String?
  amount       Float
  termMonths   Int
  status       String
  providerData Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
  vehicle      Vehicle? @relation(fields: [vehicleId], references: [id])
}

model Payment {
  id          String        @id @default(cuid())
  userId      String
  amount      Float
  currency    String        @default("USD")
  provider    String
  providerRef String?
  status      PaymentStatus @default(PENDING)
  metadata    Json?
  createdAt   DateTime      @default(now())
  user        User          @relation(fields: [userId], references: [id])
}

model Shipment {
  id           String         @id @default(cuid())
  bookingRef   String?        @unique
  carrier      String?
  containerNo  String?
  status       ShipmentStatus @default(CREATED)
  origin       String?
  destination  String?
  eta          DateTime?
  vehicleId    String?
  trackingMeta Json?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  vehicle      Vehicle?       @relation(fields: [vehicleId], references: [id])
}

model InspectionReport {
  id          String   @id @default(cuid())
  vehicleId   String
  inspectorId String
  photos      Json?
  notes       String?
  score       Int?
  createdAt   DateTime @default(now())
  inspector   User     @relation(fields: [inspectorId], references: [id])
  vehicle     Vehicle  @relation(fields: [vehicleId], references: [id])
}

model Notification {
  id        String    @id @default(cuid())
  userId    String
  channel   String
  payload   Json
  read      Boolean   @default(false)
  sentAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id])
}

model Report {
  id          String   @id @default(cuid())
  name        String
  params      Json
  result      Json?
  generatedBy String?
  createdAt   DateTime @default(now())
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  resource   String?
  resourceId String?
  payload    Json?
  createdAt  DateTime @default(now())
  actor      User?    @relation(fields: [actorId], references: [id])
}

model ExchangeRate {
  id        String   @id @default(cuid())
  base      String
  target    String
  rate      Float
  fetchedAt DateTime @default(now())
  source    String?
}

model VinDecodeCache {
  id       String   @id @default(cuid())
  vin      String   @unique
  data     Json
  cachedAt DateTime @default(now())
}

model Brand {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  logoUrl     String?
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  vehicles    Vehicle[]
}

model Category {
  id          String    @id @default(cuid())
  name        String    @unique
  slug        String    @unique
  description String?
  featured    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  vehicles    Vehicle[]
}

model Page {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  heroText    String?
  content     Json?
  metadata    Json?
  status      ContentStatus @default(DRAFT)
  publishedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model BlogPost {
  id          String        @id @default(cuid())
  title       String
  slug        String        @unique
  summary     String?
  content     Json?
  authorId    String?
  publishedAt DateTime?
  status      ContentStatus @default(DRAFT)
  featured    Boolean       @default(false)
  tags        String[]      @default([])
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  author      User?         @relation(fields: [authorId], references: [id])
}

model SupportTicket {
  id           String           @id @default(cuid())
  userId       String?
  name         String?
  email        String?
  phone        String?
  subject      String
  message      String
  status       SupportStatus    @default(OPEN)
  assignedToId String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  messages     SupportMessage[]
  assignedTo   User?            @relation("assignedSupport", fields: [assignedToId], references: [id])
  user         User?            @relation(fields: [userId], references: [id])
}

model SupportMessage {
  id        String        @id @default(cuid())
  ticketId  String
  senderId  String?
  content   String
  metadata  Json?
  createdAt DateTime      @default(now())
  sender    User?         @relation(fields: [senderId], references: [id])
  ticket    SupportTicket @relation(fields: [ticketId], references: [id])
}

model ContactInquiry {
  id          String        @id @default(cuid())
  name        String
  email       String
  phone       String?
  subject     String
  message     String
  status      SupportStatus @default(OPEN)
  response    String?
  respondedAt DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ImportQuote {
  id           String            @id @default(cuid())
  userId       String?
  origin       String
  destination  String
  vehicleType  String
  priceRange   String
  estimatedFee Float?
  currency     String            @default("USD")
  status       ImportQuoteStatus @default(REQUESTED)
  metadata     Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  user         User?             @relation(fields: [userId], references: [id])
}

enum UserRole {
  CUSTOMER
  DEALER
  INSPECTOR
  DRIVER
  ADMIN
}

enum AuctionStatus {
  DRAFT
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum VehicleCondition {
  NEW
  USED
  SALVAGE
  REBUILT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum ShipmentStatus {
  CREATED
  PICKED_UP
  IN_TRANSIT
  DELIVERED
  CANCELLED
}

enum ContentStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum SupportStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum ImportQuoteStatus {
  REQUESTED
  QUOTED
  BOOKED
  CANCELLED
}
